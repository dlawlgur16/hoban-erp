# ──────────── 운영 환경 변수 ────────────
# Amplify Console > App settings > Environment variables 에 동일하게 등록

# PostgreSQL 연결 문자열
# 로컬 개발: npx prisma dev 가 알려주는 값
# 운영(RDS): postgresql://<user>:<password>@<host>.<region>.rds.amazonaws.com:5432/hoban_erp?sslmode=require
DATABASE_URL="postgresql://USER:PASS@HOST:5432/DBNAME?sslmode=require"

# 어드민 비밀번호 (실무자/대표님 로그인용)
ADMIN_PASSWORD="CHANGE_ME"

# 세션 쿠키 서명 비밀 (32바이트 base64)
# 생성: openssl rand -base64 32
SESSION_SECRET="CHANGE_ME_32_BYTE_BASE64"
